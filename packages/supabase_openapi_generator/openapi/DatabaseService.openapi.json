                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "filters",
                        "in": "query",
                        "description": "Horizontal filters \u2014 rows matching these filters will be deleted.",
                        "style": "form",
                        "schema": {
                            "$ref": "#/components/schemas/StringMap"
                        }
                    },
                    {
                        "name": "Content-Profile",
                        "in": "header",
                        "schema": {
                            "type": "string"
                        }
