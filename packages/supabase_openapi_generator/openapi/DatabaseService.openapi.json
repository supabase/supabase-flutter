                            "type": "string",
                            "description": "Target a non-default schema for the write."
                        }
                    },
                    {
                        "name": "Prefer",
                        "in": "header",
                        "description": "Return behavior and conflict handling.\ne.g. \"return=representation\", \"return=minimal\" (default),\n     \"return=headers-only\", \"resolution=merge-duplicates\".",
                        "schema": {
                            "type": "string",
                            "description": "Return behavior and conflict handling.\ne.g. \"return=representation\", \"return=minimal\" (default),\n     \"return=headers-only\", \"resolution=merge-duplicates\"."
                        }
