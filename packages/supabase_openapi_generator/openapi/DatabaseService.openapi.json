                            "description": "Columns to match for conflict detection (if not the primary key)."
                        }
                    },
                    {
                        "name": "filters",
                        "in": "query",
                        "description": "Horizontal filters \u2014 rows matching these filters will be upserted.",
                        "style": "form",
                        "schema": {
                            "$ref": "#/components/schemas/StringMap"
                        }
                    },
                    {
                        "name": "Content-Profile",
                        "in": "header",
                        "schema": {
                            "type": "string"
                        }
                    },
                    {
                        "name": "Prefer",
                        "in": "header",
                        "description": "e.g. \"return=representation\", \"resolution=merge-duplicates\",\n     \"resolution=ignore-duplicates\".",
