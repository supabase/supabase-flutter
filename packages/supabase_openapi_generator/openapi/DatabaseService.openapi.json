                    {
                        "name": "Prefer",
                        "in": "header",
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "UpdateRows 200 response",
                        "headers": {
                            "Content-Range": {
                                "description": "Pagination info \u2014 e.g. \"0-9/200\" (range/total) or \"0-9/*\" (unknown count).",
                                "schema": {
                                    "type": "string",
                                    "description": "Pagination info \u2014 e.g. \"0-9/200\" (range/total) or \"0-9/*\" (unknown count)."
                                }
                            }
                        },
                        "content": {
                            "application/octet-stream": {
                                "schema": {
                                    "$ref": "#/components/schemas/UpdateRowsOutputPayload"
                                }
                            }
