                            "description": "Ordering \u2014 e.g. \"name.asc,age.desc.nullslast\""
                        }
                    },
                    {
                        "name": "limit",
                        "in": "query",
                        "description": "Maximum number of rows to return.",
                        "schema": {
                            "type": "number",
                            "description": "Maximum number of rows to return."
                        }
                    },
                    {
                        "name": "offset",
                        "in": "query",
                        "description": "Row offset for pagination.",
